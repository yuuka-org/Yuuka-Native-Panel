APP_NAME="Yuuka Server Panel"
APP_ENV=production
APP_KEY=
APP_URL=https://panel.example.com
APP_DEPLOYMENT_MODE=direct

DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=server_panel
DB_USERNAME=panel_app
DB_PASSWORD=

DB_PROVISIONER_USERNAME=panel_provisioner
DB_PROVISIONER_PASSWORD=

SESSION_LIFETIME=1800
SESSION_IDLE_TIMEOUT=900
SESSION_SECURE_COOKIE=1

PANEL_EXEC_SCRIPT=/opt/server-panel/scripts/panel-exec.sh
NODEAPPS_HOME=/home/nodeapps
NGINX_SITES_AVAILABLE=/etc/nginx/sites-available
NGINX_SITES_ENABLED=/etc/nginx/sites-enabled
ACME_WEBROOT=/var/www/_letsencrypt

LOG_PATH=/opt/server-panel/storage/logs
BACKUP_PATH=/opt/server-panel/storage/backups

# Batas ukuran per file untuk File Manager (upload file individual & upload ZIP).
# Ubah kapan saja tanpa perlu restart Nginx/PHP-FPM - dibaca ulang tiap request.
FILEMANAGER_MAX_UPLOAD_MB=100
